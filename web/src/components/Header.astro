---
import AddressBar from "@/components/AddressBar.tsx"
import { useTranslations, type language } from "@/i18n/ui"
import ThemeIcon from "./ThemeIcon.astro"

const { lang } = Astro.props
const t = useTranslations(lang as language)
---

<header class="bg-sidebar border-b py-3 shadow-2xs">
  <div
    class="mx-auto flex w-[92%] max-w-6xl flex-wrap items-center gap-3 px-2.5 sm:px-4.5"
  >
    <img alt="logo" src="/favicon.svg" class="h-7" />
    <span class="text-lg font-semibold">{t("title")}</span>
    <div class="ml-auto sm:order-3 sm:ml-0">
      <ThemeIcon />
    </div>
    <div class="w-full sm:order-2 sm:ml-auto sm:w-auto">
      <AddressBar lang={lang} client:load />
    </div>
  </div>
</header>
